# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Unit test / coverage reports
.pytest_cache/
.coverage

# Virtual environments
venv/
.venv/
env/
ENV/
venv.bak/

# Environment variables file (do not commit secrets)
.env
.env.local
.env.*.local



# pyenv
.python-version

# mypy
.mypy_cache/

# VS Code workspace storage (keep settings files, ignore workspace storage)
.vscode/.workspace/*

# Local python environment file (if you store interpreter info)
python_env.json

# Editor backups
*~
.DS_Store

# NestHub runtime local state and generated artifacts
nethub_runtime/core/config/semantic_policy_memory.sqlite3
nethub_runtime/generated/agents/*.json
nethub_runtime/generated/blueprints/*.json
nethub_runtime/generated/code/*
nethub_runtime/generated/features/*
nethub_runtime/generated/local_models/*
nethub_runtime/generated/traces/*.json


# examples
examples/*.html
examples/*.png

.public_api_temp/*.*

# External log snapshots (fetched from Railway public_api)
nethub_runtime/external_logs/
api/public_api/received/
