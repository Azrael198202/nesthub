{
  "version": "core_plus_v2",
  "signal_sets": {
    "needs_external": ["latest", "current", "official", "price", "release", "today", "最新", "当前", "官网", "价格", "新闻", "发布"],
    "needs_rag": ["summary", "document", "knowledge", "history", "memory", "总结", "文档", "知识", "历史"],
    "needs_planning": ["plan", "workflow", "agent", "steps", "design", "规划", "方案", "分步骤", "设计"]
  },
  "intent_rules": [
    {
      "rule_id": "schedule_rule",
      "markers": ["提醒", "明天", "后天", "日程", "会议"],
      "intent": "schedule_create",
      "workflow": "schedule_graph",
      "confidence": 0.82
    },
    {
      "rule_id": "record_rule",
      "markers": ["花了", "消费", "金额", "支出", "记录"],
      "intent": "record_expense",
      "workflow": "expense_record_graph",
      "confidence": 0.82
    },
    {
      "rule_id": "document_rule",
      "markers": ["整理文档", "总结", "提取要点", "摘要"],
      "intent": "document_summary",
      "workflow": "document_summary_graph",
      "confidence": 0.8
    },
    {
      "rule_id": "external_rule",
      "markers": ["查一下", "最新", "价格", "官网", "新闻"],
      "intent": "external_lookup",
      "workflow": "external_search_graph",
      "confidence": 0.84
    }
  ],
  "graph_routes": {
    "schedule_graph": ["schedule_create", "reminder_create"],
    "expense_record_graph": ["record_expense", "data_record"],
    "document_summary_graph": ["document_summary", "file_generation_task"],
    "external_search_graph": ["external_lookup", "web_research_task"],
    "rag_qa_graph": ["faq_answer", "query_agent_knowledge", "data_query"]
  },
  "capability_orchestration": {
    "patterns": [
      {
        "pattern_id": "schedule_availability_and_trip_plan",
        "markers": ["看看我的日程", "没有预约", "制定", "观光计划", "提醒", "飞机时间"],
        "local_capabilities": ["schedule_availability_query", "reminder_create_trigger"],
        "external_capabilities": ["travel_itinerary_generation"],
        "force_need_external": true,
        "trigger_autonomous_implementation": true
      }
    ]
  },
  "state_layers": {
    "session": ["session_id", "trace_id", "queued_review", "dialog_turns"],
    "user_long_term": ["preferences", "memory_profile", "knowledge_refs"],
    "task_execution": ["intent", "workflow", "selected_graph", "evaluation", "pending_review"]
  },
  "human_review": {
    "pause_on_missing_fields": true,
    "pause_on_knowledge_conflict": true,
    "reviewable_issue_codes": ["missing_information", "uncertain_amount", "ambiguous_date", "knowledge_conflict"],
    "required_fields": {
      "expense_record_graph": ["amount", "date"],
      "schedule_graph": ["date", "time"],
      "document_summary_graph": ["document_reference"],
      "rag_qa_graph": ["query"]
    }
  },
  "retrieval": {
    "knowledge_namespaces": ["core_plus_capability", "core_plus_policy", "core_plus_workflow", "core_plus_runtime"],
    "providers": {
      "vector": ["weaviate", "qdrant", "pgvector", "memory"],
      "document": ["postgresql", "elasticsearch", "opensearch", "filesystem"],
      "graph": ["neo4j", "networkx", "memory"]
    },
    "default_backends": {
      "vector": "memory",
      "document": "filesystem",
      "graph": "memory"
    }
  },
  "fallback": {
    "graph": "external_search_graph",
    "conditions": ["low_confidence", "missing_required_fields", "need_latest_external_information", "planning_complexity_high", "insufficient_knowledge_retrieval"]
  },
  "data_routing": {
    "knowledge_base_threshold": 0.9,
    "training_pool_threshold": 0.65,
    "fallback_threshold": 0.72,
    "stable_intents": ["data_record", "record_expense", "query_agent_knowledge", "capture_agent_knowledge"]
  },
  "knowledge_sources": [
    {
      "source_id": "semantic_policy",
      "type": "json_file",
      "path": "nethub_runtime/core/config/semantic_policy.json",
      "namespace": "core_plus_policy"
    },
    {
      "source_id": "vector_policy",
      "type": "json_file",
      "path": "nethub_runtime/core/config/vector_store_policy.json",
      "namespace": "core_plus_runtime"
    },
    {
      "source_id": "profile_seed",
      "type": "json_file",
      "path": "nethub_runtime/config/core_plus_seed_knowledge.json",
      "namespace": "core_plus_capability"
    }
  ]
}