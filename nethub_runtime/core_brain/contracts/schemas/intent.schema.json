{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nethub.local/schemas/intent.schema.json",
  "title": "Intent Schema",
  "description": "Structured intent for core_brain. Supports normal intent and agent creation intent.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_type": {
      "type": "string",
      "enum": [
        "normal_intent",
        "agent_creation_intent"
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "description": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "entities": {
      "type": "object",
      "description": "Structured extracted entities. Shape is task-dependent.",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "expected_outcome": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "requires_clarification": {
      "type": "boolean"
    },
    "clarification_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_text": {
      "type": "string",
      "minLength": 1
    },
    "context_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "type": "string"
        },
        "task_session_id": {
          "type": "string"
        },
        "memory_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "intent_id",
    "intent_type",
    "name",
    "description",
    "confidence",
    "entities",
    "constraints",
    "expected_outcome",
    "requires_clarification",
    "clarification_questions",
    "source_text"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "intent_type": {
            "const": "agent_creation_intent"
          }
        }
      },
      "then": {
        "properties": {
          "entities": {
            "type": "object",
            "required": [
              "agent_role"
            ],
            "properties": {
              "agent_role": {
                "type": "string",
                "minLength": 1
              },
              "target_domain": {
                "type": "string"
              },
              "required_capabilities": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "required_tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ]
}