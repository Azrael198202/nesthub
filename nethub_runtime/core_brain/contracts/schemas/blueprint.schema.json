{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nethub.local/schemas/blueprint.schema.json",
  "title": "Blueprint Schema",
  "description": "Structured runtime definition of an agent type.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "blueprint_id": {
      "type": "string",
      "minLength": 1
    },
    "blueprint_type": {
      "type": "string",
      "enum": [
        "agent_blueprint",
        "tool_blueprint",
        "workflow_blueprint"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "agent_role": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_intents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tool_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "resolution_strategy": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "prebuilt",
                "external_adapter",
                "generated_code"
              ]
            },
            "minItems": 1
          },
          "min_version": {
            "type": "string"
          }
        },
        "required": [
          "tool_name",
          "required",
          "resolution_strategy"
        ]
      }
    },
    "input_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "schema_name"
      ]
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "schema_name"
      ]
    },
    "execution_policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "trace_required": {
          "type": "boolean"
        },
        "step_validation_required": {
          "type": "boolean"
        },
        "fallback_agent_role": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "max_retries",
        "trace_required",
        "step_validation_required",
        "fallback_agent_role"
      ]
    },
    "collaboration_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "can_delegate_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "can_receive_from": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "can_delegate_to",
        "can_receive_from"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "registered",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "blueprint_id",
    "blueprint_type",
    "version",
    "agent_role",
    "display_name",
    "description",
    "supported_intents",
    "capabilities",
    "tool_requirements",
    "input_contract",
    "output_contract",
    "execution_policies",
    "collaboration_rules",
    "status"
  ]
}