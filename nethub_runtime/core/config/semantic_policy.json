{
  "tokenizer": {
    "preferred": "jieba",
    "fallback": "regex",
    "min_token_length": 2
  },
  "semantic_matching": {
    "method": "embedding_or_token",
    "embedding_model": "paraphrase-multilingual-MiniLM-L12-v2",
    "similarity_threshold": 0.62,
    "fallback_to_external_threshold": 0.35
  },
  "normalization": {
    "text_replace": {
      "￥": "元",
      "円": "日元"
    },
    "synonyms": {
      "self": [
        "我",
        "我个人",
        "本人"
      ]
    }
  },
  "semantic_label_threshold": 0.2,
  "semantic_label_margin": 0.08,
  "entity_aliases": {
    "actor": {
      "self": [
        "我",
        "我个人",
        "本人"
      ],
      "家人": [
        "家人",
        "家庭成员"
      ],
      "朋友": [
        "朋友",
        "好友"
      ]
    }
  },
  "ignored_query_tokens": [
    "多少",
    "一共",
    "总额",
    "是多少",
    "吗"
  ],
  "label_taxonomy": {
    "transportation": {
      "description": "travel and transportation expenses",
      "examples": [
        "打车",
        "出租车",
        "地铁",
        "公交",
        "车费",
        "机场"
      ]
    },
    "healthcare": {
      "description": "healthcare and medicine expenses",
      "examples": [
        "医院",
        "看病",
        "买药",
        "药店",
        "诊所"
      ]
    },
    "utilities": {
      "description": "utility and network expenses",
      "examples": [
        "网费",
        "水费",
        "电费",
        "燃气费"
      ]
    }
  },
  "record_type_rules": {
    "schedule": {
      "require_time": true,
      "required_any": [
        "去",
        "前往",
        "开会",
        "安排",
        "日程"
      ]
    },
    "generic": {
      "default": true,
      "default_label": "other"
    }
  },
  "query_metric_rules": {},
  "segment_split_patterns": [
    "[。；;\\n]",
    "还有",
    "并且",
    "\\band\\b"
  ],
  "location_markers": [
    "在",
    "去",
    "于",
    "at",
    "in"
  ],
  "location_keyword_patterns": [
    "([\\u4e00-\\u9fffA-Za-z0-9]{2,})地区"
  ],
  "participant_pattern": "(\\d+)\\s*人",
  "participant_aliases": {
    "两个人": 2,
    "三个人": 3
  },
  "content_cleanup_patterns": [
    "\\d+(?:\\.\\d+)?\\s*(日元|円|yen|usd|rmb|元|块|美元|￥|\\$)?"
  ],
  "content_strip_chars": " ，,.。",
  "group_by_aliases": {
    "按时间": "time",
    "按类别": "label",
    "按地点": "location",
    "按人员": "actor",
    "按人": "actor",
    "by time": "time",
    "by label": "label",
    "by location": "location",
    "by actor": "actor"
  },
  "actor_extract_patterns": [
    "^(?:记录|添加|保存)?([\\u4e00-\\u9fffA-Za-z]{2,4})(?=今天|昨天|本周|下周|\\d{1,2}月\\d{1,2}[号日]|去|到|前往)",
    "^([A-Za-z][A-Za-z0-9_-]{1,20})(?=\\s+\\d{4}-\\d{2}-\\d{2}|\\s+\\d{1,2}/\\d{1,2})"
  ],
  "explicit_date_patterns": [
    {
      "pattern": "(\\d{1,2})月(\\d{1,2})[号日]",
      "month_group": 1,
      "day_group": 2
    },
    {
      "pattern": "(\\d{4})-(\\d{2})-(\\d{2})",
      "year_group": 1,
      "month_group": 2,
      "day_group": 3
    }
  ],
  "relative_week_rules": [
    {
      "pattern": "本周([一二三四五六日天])",
      "weekday_group": 1,
      "weekday_map": {
        "一": 0,
        "二": 1,
        "三": 2,
        "四": 3,
        "五": 4,
        "六": 5,
        "日": 6,
        "天": 6
      },
      "week_start": "monday"
    }
  ],
  "boolean_aliases": {
    "truthy": [
      "是",
      "参与",
      "需要",
      "yes",
      "true",
      "y",
      "1"
    ],
    "falsy": [
      "否",
      "不",
      "no",
      "false",
      "n",
      "0"
    ]
  },
  "model_semantic_parser": {
    "enabled": true,
    "prefer_model_for_query_parsing": true,
    "prefer_model_for_record_extraction": true,
    "strict_schema_validation": true,
    "router": "litellm",
    "task_types": {
      "record_extraction": "semantic_parsing",
      "query_parsing": "semantic_parsing",
      "aggregation": "semantic_aggregation",
      "policy_learning": "semantic_learning",
      "labeling": "semantic_labeling"
    }
  },
  "time_marker_rules": {
    "today": {
      "aliases": [
        "今天",
        "今日",
        "today"
      ],
      "match_mode": "same_day",
      "record_aliases": [
        "今天",
        "今日",
        "today"
      ]
    },
    "current_month": {
      "aliases": [
        "这个月",
        "本月",
        "this month"
      ],
      "match_mode": "same_month",
      "record_aliases": [
        "今天",
        "今日",
        "这个月",
        "本月",
        "today",
        "this month",
        "unspecified"
      ]
    },
    "previous_week": {
      "aliases": [
        "上周",
        "上周末",
        "last week"
      ],
      "match_mode": "prefix",
      "prefixes": [
        "上周",
        "last week"
      ]
    }
  },
  "policy_memory": {
    "enabled": true,
    "backend": "sqlite",
    "read_only_main_policy": true,
    "auto_candidate_zone": true,
    "auto_activate": {
      "enabled": true,
      "min_hits": 2,
      "min_confidence": 0.75
    },
    "learning": {
      "enabled": true,
      "extractor": "model",
      "max_updates_per_text": 8,
      "default_confidence": 0.82,
      "allowed_policy_keys": [
        "location_markers",
        "ignored_query_tokens",
        "time_markers",
        "segment_split_patterns",
        "location_keyword_patterns",
        "participant_aliases",
        "group_by_aliases",
        "entity_aliases.actor",
        "record_type_rules",
        "query_metric_rules"
      ],
      "min_candidate_text_length": 2,
      "blocked_terms": [
        "多少",
        "一共",
        "总额",
        "统计",
        "查询",
        "花了",
        "今天",
        "这个月",
        "上周",
        "类别",
        "地点",
        "人员",
        "total",
        "count",
        "query",
        "today",
        "this month",
        "last week",
        "label",
        "location",
        "actor"
      ],
      "reject_existing_conflicts": true
    },
    "self_heal": {
      "enabled": true,
      "max_failures": 2,
      "rollback_batch_size": 3
    }
  },
  "external_semantic_router": {
    "enabled": false,
    "provider_priority": [
      "openai",
      "claude"
    ],
    "openai": {
      "model": "gpt-4o",
      "api_env": "OPENAI_API_KEY"
    },
    "claude": {
      "model": "claude-3-5-sonnet-latest",
      "api_env": "ANTHROPIC_API_KEY"
    },
    "generic_endpoint_env": "NETHUB_LLM_ROUTER_ENDPOINT"
  }
}
