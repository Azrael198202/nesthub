{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run NetHub Runtime (main)",
      "type": "python",
      "request": "launch",
      "module": "nethub_runtime.main",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run App (nethub_runtime.app.main)",
      "type": "python",
      "request": "launch",
      "module": "nethub_runtime.app.main",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run TV Box UI (nethub_runtime.ui.tvbox.main)",
      "type": "python",
      "request": "launch",
      "module": "nethub_runtime.ui.tvbox.main",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run AI Core API + Open Semantic Dashboard",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "nethub_runtime.core.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://\\S+)",
        "uriFormat": "%s/examples/semantic-memory-dashboard/",
        "action": "openExternally"
      }
    }
  ]
}
