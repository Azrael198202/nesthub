# Example environment file for sensitive configuration values.
# Copy to `.env` and fill with real values. `.env` is in .gitignore and will not be committed.

# General API credentials
API_KEY=
API_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NETHUB_LLM_ROUTER_ENDPOINT=

# Mail server / account
MAIL_ADDRESS=you@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USER=you@example.com
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_USE_SSL=false
